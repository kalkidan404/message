<!DOCTYPE html>
<html>
<head>
  <title>Mini Messageboard</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <h1>Mini Messageboard</h1>

  <a href="/new">Add New Message</a>

  <hr>

  <% messages.forEach((message, index) => { %>

    <div class="message-card">
      <h3><%= message.user %></h3>

      <p><%= message.text %></p>

      <small><%= message.added %></small>

      <br>

      <a href="/message/<%= index %>">Open</a>
    </div>

    <hr>

  <% }); %>

</body>
</html>